{
  "name": "crux-studio",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev": "pnpm --parallel --filter @crux-studio/server --filter @crux-studio/web dev",
    "dev:local": "CRUX_STUDIO_PROVIDER=local CRUX_HARNESS_ROOT=${CRUX_HARNESS_ROOT:-/Users/nikolacehic/Desktop/crux-harness} pnpm dev",
    "smoke:local": "node scripts/smoke-local.mjs",
    "test": "pnpm -r test",
    "verify": "pnpm test && pnpm check && pnpm build"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
